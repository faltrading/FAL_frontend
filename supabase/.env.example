# ──────────────────────────────────────────────────────
# FAL Frontend — Supabase Environment Variables
# ──────────────────────────────────────────────────────

# Used by the FRONTEND (browser-safe, public):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Used ONLY by the setup script (server-side, NEVER expose to browser):
# Required for: npm run db:setup
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
